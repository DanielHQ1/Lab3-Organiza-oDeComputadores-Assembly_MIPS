.data
msg_qtd: .asciiz "Digite a quantidade de numeros (N > 0): "
msg_erro: .asciiz "Erro: N deve ser maior que 0. Tente novamente.\n"
msg_n: .asciiz "Digite o numero: "
msg_ord: .asciiz "\nVetor ordenado: "
msg_comp: .asciiz "\nTotal de comparacoes: "
msg_troca: .asciiz "\nTotal de trocas: "
espaco: .asciiz " "

.text
.globl main

main:
ler_qtd:
    li $v0, 4
    la $a0, msg_qtd			#printa numero de elemtentos do vetor pro usuario
    syscall

    li $v0, 5           		# le inteiro n
    syscall
    move $s1, $v0       

    bgt $s1, $zero, alocar_memoria 	#verifica se a entrada eh maior que ZERO, se for, jump para alocar_memoria
    
    li $v0, 4
    la $a0, msg_erro			# se n for menor que 0, mostra mensagem de erro
    syscall
    j ler_qtd

alocar_memoria:
    mul $a0, $s1, 4   			#cada inteiro ocupa 4 bytes logo a0 = N * 4 bytes
    
    li $v0, 9           		# syscall 9: sbrk (aloca memoria)
    syscall
    move $s0, $v0      		 	# s0 = Endereco base do array alocado

    li $t1, 0           		# t1 = contador (0 ate N-1)
    move $t2, $s0       		# t2 = ponteiro atual do array

loop_leitura:
    bge $t1, $s1, fim_leitura		# verifica se i eh maior ou igualo a n, se sim, jump para fim da leitura	
    
    li $v0, 4
    la $a0, msg_n			#printa msg_n para o usuario
    syscall

    li $v0, 5           		# le numero
    syscall
    
    sw $v0, 0($t2)      		# armazena numero no vetor

    addi $t2, $t2, 4    		# avanca ponteiro do vetor
    addi $t1, $t1, 1    		# add 1 no contador
    j loop_leitura			# pula para o comeco

fim_leitura:
#bublle sort
    li $s2, 0           		# s2 = contador de comparacoes
    li $s3, 0           		# s3 = contador de trocas
    
    addi $t0, $s1, -1   		# t0 = limite do loop externo (N - 1)

loop_externo:
    blez $t0, fim_sort  		# se limite <= 0, o array esta ordenado
    
    li $t1, 0           		# $t1 = contador do loop interno (j)
    move $t2, $s0       		# $t2 = ponteiro percorrendo o array

loop_interno:
    bge $t1, $t0, fim_interno
    
    lw $t3, 0($t2)      		# vetor[j]
    lw $t4, 4($t2)      		# vetor[j+1]
    
    addi $s2, $s2, 1    		# add 1 no contador de comparacoes
    
    ble $t3, $t4, nao_troca  		# se vetor[j] <= vetor[j+1] pula para nao_troca
    
#se nao faz a troca:
    sw $t4, 0($t2)			# salva o valor menor em A[j]
    sw $t3, 4($t2)			# salva o valor maior em A[j+1]
    addi $s3, $s3, 1    		# add 1 no contador de trocas

nao_troca:
    addi $t2, $t2, 4    		# avanca ponteiro
    addi $t1, $t1, 1    		# incrementa 1 em j
    j loop_interno

fim_interno:
    addi $t0, $t0, -1   		# reduz o limite do loop externo
    j loop_externo

fim_sort:
#prints
    li $v0, 4
    la $a0, msg_ord			# printa msg_ord pro usuario
    syscall

    li $t1, 0           		# contador
    move $t2, $s0       		# ponteiro

loop_imprime:
    bge $t1, $s1, fim_imprime		# verifica se cont eh maior ou igualo a n , se sim, jump para fim_imprime
    
    lw $a0, 0($t2)
    li $v0, 1           		# imprime inteiro
    syscall
    
    li $v0, 4
    la $a0, espaco     			# imprime espaco
    syscall

    addi $t2, $t2, 4			# avanca o ponteiro para prox memoria
    addi $t1, $t1, 1			# add 1 no contador
    j loop_imprime

fim_imprime:
  
    li $v0, 4
    la $a0, msg_comp
    syscall				# imprime comparacoes
    move $a0, $s2			
    li $v0, 1
    syscall

    li $v0, 4
    la $a0, msg_troca
    syscall				# imprime trocas
    move $a0, $s3
    li $v0, 1
    syscall

    li $v0, 10				#executa fim do programa
    syscall
